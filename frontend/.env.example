# Frontend Environment Variables
# Copy this file to `.env.local` for local development
# Vite only exposes variables prefixed with VITE_ to the client bundle

# ── API Configuration ──────────────────────────────────────────────────────
# Local development (running backend on localhost)
VITE_API_URL=http://localhost:8000

# Production (replace with your Railway backend URL)
# VITE_API_URL=https://your-railway-backend.railway.app

# ── Supabase (session persistence) ─────────────────────────────────────────
# Optional: Get these from https://supabase.com/dashboard
# Settings → API → Project URL and anon/public key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Analytics (optional) ───────────────────────────────────────────────────
VITE_ENABLE_ANALYTICS=false
