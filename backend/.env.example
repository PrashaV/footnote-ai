# Backend Environment Variables
# Copy this file to `.env` and fill in real values
# ⚠️  NEVER commit .env to git — it is in .gitignore

# ── Required: Anthropic API ────────────────────────────────────────────────
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Model Configuration ──────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT_SECONDS=60

# ── Required: Supabase ─────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# ⚠️  Use the SERVICE ROLE key here (not the anon key).
# The service role key bypasses RLS so the backend can write to any table
# without being subject to per-user policies.
# Location: Supabase Dashboard → Settings → API → "service_role" (secret)
# NEVER expose this key in the frontend — server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ⚠️  JWT Secret — used to validate every user's Bearer token on the backend.
# Location: Supabase Dashboard → Settings → API → JWT Settings → "JWT Secret"
# Also add this to Railway: Project → Variables → SUPABASE_JWT_SECRET
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── CORS Configuration ─────────────────────────────────────────────────────
# Local development
FRONTEND_URL=http://localhost:5173

# Production (replace with your Vercel frontend URL)
# FRONTEND_URL=https://footnote.vercel.app

# ── Sapling — AI writing detection ────────────────────────────────────────
# Get a free key at https://sapling.ai/user/login (no credit card required)
# Without this key, AI writing detection will be disabled gracefully.
SAPLING_API_KEY=

# ── Academic Integrity Engine — External Citation APIs ─────────────────────
# Semantic Scholar: optional key raises rate limits
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# CrossRef and OpenAlex are free and require no key.
# Set your app email for OpenAlex polite pool (recommended):
OPENALEX_EMAIL=your-email@example.com

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ────────────────────────────────────────────────────────────────
# Railway sets PORT automatically; used for local development
PORT=8000
